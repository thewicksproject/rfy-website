---
layout: base.njk
title: Contact Us
description: Get in touch with Reach For Youth for services, volunteer opportunities, or any questions about our programs.
---

<section class="page-hero">
  <div class="container">
    <h1 class="page-hero__title">Contact Us</h1>
    <p class="page-hero__subtitle">
      We're here to help. Reach out for services, volunteer opportunities,
      or any questions you may have.
    </p>
  </div>
</section>

<style>
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }
  .contact-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
    border-top: 6px solid var(--color-primary);
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .contact-card--pink   { border-top-color: var(--color-accent); }
  .contact-card--orange { border-top-color: var(--color-accent-dark); }
  .contact-card--navy   { border-top-color: var(--color-primary); }
  .contact-card--purple { border-top-color: var(--color-primary-light); }
  .contact-card--teal   { border-top-color: var(--color-accent-light); }

  .contact-card__icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.5rem;
    margin-bottom: var(--space-xs);
  }
  .contact-card__icon svg { width: 24px; height: 24px; }
  .contact-card--pink   .contact-card__icon { background: linear-gradient(135deg, var(--color-accent), #FF5CA3); }
  .contact-card--orange .contact-card__icon { background: linear-gradient(135deg, var(--color-accent-dark), #FF9A5C); }
  .contact-card--navy   .contact-card__icon { background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light)); }
  .contact-card--purple .contact-card__icon { background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent)); }
  .contact-card--teal   .contact-card__icon { background: linear-gradient(135deg, var(--color-accent-light), #4ADDB5); color: var(--color-primary); }

  .contact-card__label {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .contact-card__value { color: var(--color-text-light); line-height: 1.6; }
  .contact-card__value a { font-weight: 600; }
  .contact-card__sub { font-size: 0.875rem; color: var(--color-text-muted); margin-top: var(--space-xs); }

  .hours-card {
    background: linear-gradient(135deg, var(--color-accent-light) 0%, #4ADDB5 100%);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    max-width: 600px;
    margin: var(--space-2xl) auto 0;
    text-align: center;
    color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }
  .hours-card h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-bottom: var(--space-lg);
    color: var(--color-primary);
  }
  .hours-card__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(0, 39, 91, 0.15);
    font-size: 1.0625rem;
  }
  .hours-card__row:last-of-type { border-bottom: none; }
  .hours-card__day { font-weight: 700; }
  .hours-card__note {
    font-size: 0.875rem;
    margin-top: var(--space-md);
    opacity: 0.85;
    font-style: italic;
  }
</style>

<section class="section">
  <div class="container">
    <h2 class="section-title" style="text-align: center;">Get in <span>Touch</span></h2>

    <div class="contact-cards">
      <div class="contact-card contact-card--pink">
        <div class="contact-card__icon"><svg aria-hidden="true"><use href="#icon-phone"/></svg></div>
        <div class="contact-card__label">Phone</div>
        <div class="contact-card__value">
          <a href="tel:{{ site.offices.central.phone | replace('-', '') }}">{{ site.offices.central.phone }}</a>
        </div>
      </div>

      <div class="contact-card contact-card--orange">
        <div class="contact-card__icon">✉️</div>
        <div class="contact-card__label">Email</div>
        <div class="contact-card__value">
          <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </div>
      </div>

      <div class="contact-card contact-card--navy">
        <div class="contact-card__icon">📍</div>
        <div class="contact-card__label">{{ site.offices.central.name }}</div>
        <div class="contact-card__value">
          {{ site.offices.central.address }}<br>
          {{ site.offices.central.city }}, {{ site.offices.central.state }} {{ site.offices.central.zip }}
        </div>
      </div>

      <div class="contact-card contact-card--purple">
        <div class="contact-card__icon">📍</div>
        <div class="contact-card__label">{{ site.offices.southside.name }}</div>
        <div class="contact-card__value">
          {{ site.offices.southside.address }}<br>
          {{ site.offices.southside.city }}, {{ site.offices.southside.state }} {{ site.offices.southside.zip }}
        </div>
        <div class="contact-card__sub">
          <a href="tel:{{ site.offices.southside.phone | replace('-', '') }}">{{ site.offices.southside.phone }}</a>
        </div>
      </div>
    </div>

    <div class="hours-card">
      <h3>Office Hours</h3>
      <div class="hours-card__row">
        <span class="hours-card__day">Monday – Thursday</span>
        <span>9:00 AM – 6:00 PM</span>
      </div>
      <div class="hours-card__row">
        <span class="hours-card__day">Friday – Sunday</span>
        <span>Closed</span>
      </div>
      <p class="hours-card__note">Evening appointments available by request</p>
    </div>
  </div>
</section>

<!-- Emergency Info -->
<section class="section section--cool emergency-section">
  <div class="container">
    <h2>Need Immediate Help?</h2>
    <p style="color: var(--color-text-light); max-width: 600px; margin: var(--space-lg) auto;">
      If you or someone you know is in crisis, please reach out immediately.
    </p>
    <div class="emergency-numbers">
      <div class="emergency-number">
        <div class="emergency-number__label">Reach For Youth</div>
        <div class="emergency-number__value">
          <a href="tel:{{ site.offices.central.phone | replace('-', '') }}">{{ site.offices.central.phone }}</a>
        </div>
      </div>
      <div class="emergency-number">
        <div class="emergency-number__label">National Crisis Line</div>
        <div class="emergency-number__value">
          <a href="tel:988">988</a>
        </div>
      </div>
      <div class="emergency-number">
        <div class="emergency-number__label">Crisis Text Line</div>
        <div class="emergency-number__value">Text HOME to 741741</div>
      </div>
    </div>
  </div>
</section>
