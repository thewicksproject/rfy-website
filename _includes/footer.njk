<footer class="footer" role="contentinfo">
  <div class="container">
    <!-- Brand + Social -->
    <div class="footer__top">
      <p class="footer__description">
        Reach For Youth is a Youth Service Bureau committed to supporting,
        representing, and protecting the rights of young people in Central Indiana.
      </p>
      <div class="footer__social" aria-label="Social media links">
        <a href="{{ site.social.facebook }}" aria-label="Facebook">
          <svg aria-hidden="true"><use href="#icon-facebook"/></svg>
        </a>
        <a href="{{ site.social.instagram }}" aria-label="Instagram">
          <svg aria-hidden="true"><use href="#icon-instagram"/></svg>
        </a>
        <a href="{{ site.social.linkedin }}" aria-label="LinkedIn">
          <svg aria-hidden="true"><use href="#icon-linkedin"/></svg>
        </a>
        <a href="{{ site.social.youtube }}" aria-label="YouTube">
          <svg aria-hidden="true"><use href="#icon-youtube"/></svg>
        </a>
        <a href="{{ site.social.twitter }}" aria-label="X (Twitter)">
          <svg aria-hidden="true"><use href="#icon-x"/></svg>
        </a>
      </div>
    </div>

    <!-- Locations — inline -->
    <div class="footer__locations">
      <div class="footer__location">
        <strong>{{ site.offices.central.name }}</strong>
        &nbsp;&bull;&nbsp; {{ site.offices.central.address }}, {{ site.offices.central.city }}, {{ site.offices.central.state }} {{ site.offices.central.zip }}
        &nbsp;&bull;&nbsp; <a href="tel:{{ site.offices.central.phone | replace('-', '') }}">{{ site.offices.central.phone }}</a>
      </div>
      <div class="footer__location">
        <strong>{{ site.offices.southside.name }}</strong>
        &nbsp;&bull;&nbsp; {{ site.offices.southside.address }}, {{ site.offices.southside.city }}, {{ site.offices.southside.state }} {{ site.offices.southside.zip }}
        &nbsp;&bull;&nbsp; <a href="tel:{{ site.offices.southside.phone | replace('-', '') }}">{{ site.offices.southside.phone }}</a>
      </div>
    </div>

    <!-- Emergency Resources — inline -->
    <div class="footer__emergency">
      <span class="footer__emergency-label">Emergency Resources:</span>
      <span>{{ site.crisisLines.marionCrisis.name }}: <a href="tel:{{ site.crisisLines.marionCrisis.phone | replace('-', '') }}">{{ site.crisisLines.marionCrisis.phone }}</a></span>
      <span class="footer__emergency-sep">&bull;</span>
      <span>{{ site.crisisLines.marionHelp.name }}: <a href="tel:{{ site.crisisLines.marionHelp.phone | replace('-', '') }}">{{ site.crisisLines.marionHelp.phone }}</a></span>
      <span class="footer__emergency-sep">&bull;</span>
      <span>{{ site.crisisLines.johnsonHelp.name }}: <a href="tel:{{ site.crisisLines.johnsonHelp.phone | replace('-', '') }}">{{ site.crisisLines.johnsonHelp.phone }}</a></span>
    </div>

    <!-- Partners -->
    <div class="footer__partners-logos">
      <a href="https://www.uwjc.org/" target="_blank" rel="noopener noreferrer">
        <img src="/images/united-way-johnson-county.png" alt="United Way of Johnson County" class="footer__partner-logo">
      </a>
      <a href="https://uwci.org/" target="_blank" rel="noopener noreferrer">
        <img src="/images/united-way-central-indiana.png" alt="United Way of Central Indiana" class="footer__partner-logo">
      </a>
      <a href="https://iysa.indiana.edu/" target="_blank" rel="noopener noreferrer">
        <img src="/images/iysa.png" alt="Indiana Youth Services Association" class="footer__partner-logo">
      </a>
    </div>

    <!-- Bottom -->
    <div class="footer__bottom">
      <p>&copy; {{ page.date.getFullYear() or "2025" }} {{ site.name }}, Inc. All rights reserved. 501(c)(3) nonprofit organization.</p>
    </div>
  </div>
</footer>
