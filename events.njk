---
layout: base.njk
title: Events
description: Join us at our upcoming events and be part of the Reach For Youth community.
---

<!-- HERO SECTION -->
<section class="hero hero--inner" aria-labelledby="hero-title">
  <div class="container">
    <div class="hero__content">
      <h1 id="hero-title" class="hero__title">Events</h1>
      <p class="hero__subtitle">
        Join us at our upcoming events and be part of the Reach For Youth community.
      </p>
    </div>
  </div>
</section>

<!-- FEATURED EVENT -->
{% if event.visible %}
<section class="section" aria-labelledby="featured-event-title">
  <div class="container">
    <div class="featured-event">
      <span class="featured-event__badge">Featured Event</span>

      <h2 id="featured-event-title" class="featured-event__name">{{ event.name }}</h2>

      <div class="featured-event__meta">
        <div class="featured-event__meta-item">
          <span class="featured-event__meta-label">Date</span>
          <span class="featured-event__meta-value">{{ event.date }}</span>
        </div>
        <div class="featured-event__meta-item">
          <span class="featured-event__meta-label">Time</span>
          <span class="featured-event__meta-value">{{ event.time if event.time else "Morning Event" }}</span>
        </div>
        <div class="featured-event__meta-item">
          <span class="featured-event__meta-label">Location</span>
          <span class="featured-event__meta-value">{{ event.location }}</span>
        </div>
        <div class="featured-event__meta-item">
          <span class="featured-event__meta-label">Status</span>
          <span class="featured-event__meta-value">{{ "Registration Open" if event.registrationUrl else "Save the Date!" }}</span>
        </div>
      </div>

      <div class="featured-event__description">
        <p style="margin-bottom: var(--space-lg);">
          {{ event.description }}
        </p>
      </div>

      <div class="featured-event__highlights">
        <h4>Each year's event features:</h4>
        <ul>
          <li>Keynote speaker sharing their journey of transformation</li>
          <li>Stories from youth and families we serve</li>
          <li>Networking with community leaders</li>
          <li>Delicious breakfast at a beautiful Indianapolis venue</li>
        </ul>
      </div>

      <div class="featured-event__ctas">
        {% if event.registrationUrl %}
        <a href="{{ event.registrationUrl }}" class="btn btn--primary" target="_blank" rel="noopener">RSVP</a>
        {% endif %}
        {% if event.donationUrl %}
        <a href="{{ event.donationUrl }}" class="btn btn--primary" target="_blank" rel="noopener">Become a Sponsor</a>
        {% endif %}
        {% if event.sponsorshipPacketUrl %}
        <a href="{{ event.sponsorshipPacketUrl }}" class="btn btn--secondary" target="_blank" rel="noopener">Sponsorship Packet</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- PROGRAM IMPACT -->
<section class="section section--warm" aria-labelledby="impact-title">
  <div class="container">
    <h2 id="impact-title" class="section-title">Program <span>Impact</span></h2>
    <p class="section-subtitle">
      {{ programImpact.description }}
    </p>

    <div class="impact-stats-grid">
      {% for stat in programImpact.stats %}
      <div class="impact-stat-card">
        <span class="impact-stat-card__number">{{ stat.number }}</span>
        <span class="impact-stat-card__label">{{ stat.label }}</span>
      </div>
      {% endfor %}
    </div>

    <div class="impact-testimonials">
      {% for outcome in programImpact.outcomes %}
      <div class="impact-testimonial">
        <span class="impact-testimonial__stat">{{ outcome.number }}</span>
        <p>{{ outcome.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- SPONSORSHIP OPPORTUNITIES -->
<section class="section" aria-labelledby="sponsorship-title">
  <div class="container">
    <h2 id="sponsorship-title" class="section-title">Sponsorship <span>Opportunities</span></h2>
    <p class="section-subtitle">
      Your sponsorship directly funds the programs that change young lives. See the real impact of each level.
    </p>

    <div class="sponsorship-levels">
      {% for level in sponsorshipLevels.items %}
      <div class="sponsorship-level">
        <span class="sponsorship-level__amount">${{ level.amount }}</span>
        <h3 class="sponsorship-level__name">{{ level.name }}</h3>
        {% if level.tagline %}
        <p class="sponsorship-level__tagline">{{ level.tagline }}</p>
        {% endif %}
        {% if level.impact %}
        <p class="sponsorship-level__impact">{{ level.impact }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <div class="sponsorship-contact">
      <p>
        For sponsorship inquiries, contact us at
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      </p>
      {% if event.sponsorshipPacketUrl or event.donationUrl %}
      <div style="margin-top: var(--space-lg); display: flex; justify-content: center; flex-wrap: wrap; gap: var(--space-md);">
        {% if event.sponsorshipPacketUrl %}
        <a href="{{ event.sponsorshipPacketUrl }}" class="btn btn--secondary" target="_blank" rel="noopener">Download Sponsorship Packet</a>
        {% endif %}
        {% if event.donationUrl %}
        <a href="{{ event.donationUrl }}" class="btn btn--primary" target="_blank" rel="noopener">Sponsor Online</a>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- OTHER WAYS TO SUPPORT -->
<section class="section section--warm" aria-labelledby="support-title">
  <div class="container">
    <h2 id="support-title" class="section-title">Other Ways to <span>Stay Connected</span></h2>
    <p class="section-subtitle">
      When events aren't in season, there are still many ways to support and engage with our mission.
    </p>

    <div class="support-grid">
      <div class="support-card">
        <div class="support-card__icon" aria-hidden="true">
          <svg><use href="#icon-heart"/></svg>
        </div>
        <h4>Newsletter Signup</h4>
        <p>Stay informed about upcoming events, program updates, and inspiring stories from the youth we serve.</p>
        <a href="mailto:{{ site.email }}?subject=Newsletter%20Signup" class="btn btn--secondary btn--small">Sign Up</a>
      </div>

      <div class="support-card">
        <div class="support-card__icon" aria-hidden="true">
          <svg><use href="#icon-user"/></svg>
        </div>
        <h4>Follow on Social Media</h4>
        <p>Connect with us on Facebook, Instagram, LinkedIn, and more to see our work in action.</p>
        <a href="#footer-social" class="btn btn--secondary btn--small">Connect</a>
      </div>

    </div>
  </div>
</section>

